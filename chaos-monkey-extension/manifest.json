{
  "manifest_version": 3,
  "name": "ChaosMonkey Tester",
  "description": "Run configurable Gremlins.js monkey testing with detailed activity logging on any page.",
  "version": "1.0.0",
  "action": {
    "default_title": "ChaosMonkey Tester",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "libs/gremlins.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
